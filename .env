# ytworkflo — Environment Variables
# Copy this file to .env and adjust values

APP_NAME=ytworkflo
DEBUG=false

# CORS — comma-separated list of allowed origins, or "*" for all
CORS_ORIGINS=["*"]

# Storage paths (created automatically if missing)
DOWNLOAD_DIR=/tmp/ytworkflo/downloads
AUDIO_DIR=/tmp/ytworkflo/audio
SUBTITLE_DIR=/tmp/ytworkflo/subtitles
THUMBNAIL_DIR=/tmp/ytworkflo/thumbnails

# Batch limits
MAX_BATCH_SIZE=50
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# yt-dlp settings
YTDLP_SOCKET_TIMEOUT=30
YTDLP_RETRIES=3
